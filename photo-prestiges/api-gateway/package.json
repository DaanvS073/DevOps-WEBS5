{
  "name": "api-gateway",
  "version": "1.0.0",
  "description": "API Gateway for Photo Prestiges",
  "main": "./bin/www",
  "scripts": {
    "start": "node ./bin/www",
    "dev": "nodemon --legacy-watch -r dotenv/config ./bin/www",
    "test": "jest --coverage",
    "lint": "npx eslint ."
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-prom-bundle": "^7.0.0",
    "http-proxy-middleware": "^3.0.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "@shelf/jest-mongodb": "^4.3.2",
    "dotenv": "^16.4.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "preset": "@shelf/jest-mongodb",
    "coveragePathIgnorePatterns": ["/node_modules/"]
  }
}
